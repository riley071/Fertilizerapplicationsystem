// Propagation ERD for Banking System
digraph {
	Customer [label=Customer shape=box]
	Account [label=Account shape=box]
	Branch [label=Branch shape=box]
	Staff [label=Staff shape=box]
	Transaction [label=Transaction shape=box]
	Loan [label=Loan shape=box]
	Payment [label=Payment shape=box]
	ATM [label=ATM shape=box]
	ATM_Transaction [label=ATM_Transaction shape=box]
	MobileBanking [label=MobileBanking shape=box]
	Customer -> Account [label=has]
	Account -> Transaction [label=includes]
	Transaction -> Staff [label=performed_by]
	Customer -> Loan [label=takes]
	Loan -> Payment [label=paid_by]
	Payment -> Staff [label=processed_by]
	Account -> ATM_Transaction [label=linked_to]
	ATM -> ATM_Transaction [label=hosts]
	Customer -> MobileBanking [label=uses]
	Branch -> Staff [label=employs]
	Account -> Branch [label=opened_at]
}
